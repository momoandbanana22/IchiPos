<Window x:Class="IchiPos.Gui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="IchiPos" Height="720" Width="560" MinHeight="600" MinWidth="440"
        Icon="/IchiPos;component/icon/IchiPos.ico">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- P-01: 投稿内容 -->
        <TextBlock Grid.Row="0" Text="投稿内容" Margin="0,0,0,4"/>
        <TextBox Grid.Row="1" x:Name="ContentTextBox"
                  Text="{Binding Content, UpdateSourceTrigger=PropertyChanged}"
                  AcceptsReturn="True" TextWrapping="Wrap"
                  Height="120" VerticalScrollBarVisibility="Auto"
                  IsEnabled="{Binding IsNotBusy}"/>

        <!-- P-02: 文字数表示 -->
        <TextBlock Grid.Row="2" Text="{Binding CharacterCountDisplay}"
                   HorizontalAlignment="Right" Margin="0,2,0,8"/>

        <!-- P-03: ファイルから読み込む -->
        <Button Grid.Row="3" x:Name="LoadFromFileButton" Content="ファイルから読み込む..."
                Click="LoadFromFileButton_Click"
                HorizontalAlignment="Left" Padding="8,4" Margin="0,0,0,12"
                IsEnabled="{Binding IsNotBusy}"/>

        <!-- P-04〜P-06: 画像フォルダ -->
        <StackPanel Grid.Row="4" Orientation="Vertical" Margin="0,0,0,4">
            <TextBlock Text="画像フォルダ" Margin="0,0,0,4"/>
            <DockPanel>
                <Button x:Name="ClearImageFolderButton" DockPanel.Dock="Right"
                        Content="クリア" Command="{Binding ClearImageFolderCommand}"
                        Padding="8,4" Margin="4,0,0,0" IsEnabled="{Binding IsNotBusy}"/>
                <Button x:Name="BrowseImageFolderButton" DockPanel.Dock="Right" Content="参照..."
                        Click="BrowseImageFolderButton_Click"
                        Padding="8,4" Margin="4,0,0,0" IsEnabled="{Binding IsNotBusy}"/>
                <TextBox Text="{Binding ImageFolderPath, Mode=OneWay}" IsReadOnly="True"/>
            </DockPanel>
            <!-- P-12: クリップボード画像貼り付け機能(G-010)の案内 -->
            <TextBlock Text="画像をコピーして Ctrl+V で貼り付けることもできます" Margin="0,4,0,0"
                       FontSize="11" Foreground="Gray"/>
        </StackPanel>

        <!-- P-07: 投稿後に画像を削除する -->
        <CheckBox Grid.Row="5" Content="投稿後に画像を削除する"
                  IsChecked="{Binding DeleteImagesAfterPost}"
                  IsEnabled="{Binding IsDeleteCheckboxEnabled}"
                  Margin="0,4,0,12"/>

        <!-- P-08: 投稿する -->
        <Button Grid.Row="6" Content="投稿する" Command="{Binding PostCommand}"
                HorizontalAlignment="Right" Padding="16,6" Margin="0,0,0,8"/>

        <!-- P-09〜P-10: 結果ログ -->
        <DockPanel Grid.Row="7" Margin="0,0,0,8">
            <DockPanel DockPanel.Dock="Top" LastChildFill="False">
                <TextBlock Text="結果ログ" VerticalAlignment="Center"/>
                <Button DockPanel.Dock="Right" Content="ログをクリア" Command="{Binding ClearLogCommand}"
                        Padding="6,2" HorizontalAlignment="Right"/>
            </DockPanel>
            <ListBox ItemsSource="{Binding LogEntries}" IsEnabled="True" MinHeight="150">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Message}" TextWrapping="Wrap">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Severity}" Value="Success">
                                            <Setter Property="Foreground" Value="Green"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Severity}" Value="Error">
                                            <Setter Property="Foreground" Value="Red"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>

        <!-- P-11: バージョン表示 -->
        <TextBlock Grid.Row="8" Text="{Binding VersionText}"
                   HorizontalAlignment="Right" Foreground="Gray"/>
    </Grid>
</Window>
