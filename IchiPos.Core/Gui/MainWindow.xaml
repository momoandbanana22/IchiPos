<Window x:Class="IchiPos.Gui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:IchiPos.Gui"
        Title="IchiPos" Height="680" Width="560" MinHeight="600" MinWidth="440"
        Icon="/IchiPos;component/icon/IchiPos.ico">
    <Window.Resources>
        <local:FilePathToThumbnailConverter x:Key="FilePathToThumbnailConverter"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Window.Resources>
    <!-- P-16: タブ(04書「ウィンドウ構成」節)。結果ログ(P-09・P-10)とバージョン表示(P-11)はタブの外側に置き、
         どちらのタブを選択していても常に表示する。 -->
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0" Margin="0,0,0,8">
        <TabItem Header="投稿">
        <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- P-01: 投稿内容、P-15: 全クリア(04書 G-013、投稿内容欄ラベル行に配置) -->
        <DockPanel Grid.Row="0" Margin="0,0,0,4">
            <Button x:Name="ClearAllButton" DockPanel.Dock="Right" Content="全クリア"
                    Command="{Binding ClearAllCommand}"
                    Padding="8,4" IsEnabled="{Binding IsNotBusy}"/>
            <TextBlock Text="投稿内容" VerticalAlignment="Center"/>
        </DockPanel>
        <TextBox Grid.Row="1" x:Name="ContentTextBox"
                  Text="{Binding Content, UpdateSourceTrigger=PropertyChanged}"
                  AcceptsReturn="True" TextWrapping="Wrap"
                  Height="120" VerticalScrollBarVisibility="Auto"
                  IsEnabled="{Binding IsNotBusy}"
                  PreviewKeyDown="ContentTextBox_PreviewKeyDown"/>

        <!-- P-02: 文字数表示 -->
        <TextBlock Grid.Row="2" Text="{Binding CharacterCountDisplay}"
                   HorizontalAlignment="Right" Margin="0,2,0,8"/>

        <!-- P-03: ファイルから読み込む、P-14: 投稿内容クリア(04書 G-012) -->
        <DockPanel Grid.Row="3" Margin="0,0,0,12">
            <Button x:Name="ClearContentButton" DockPanel.Dock="Right"
                    Content="クリア" Command="{Binding ClearContentCommand}"
                    Padding="8,4" IsEnabled="{Binding IsNotBusy}"/>
            <Button x:Name="LoadFromFileButton" Content="ファイルから読み込む..."
                    Click="LoadFromFileButton_Click"
                    HorizontalAlignment="Left" Padding="8,4" Margin="0,0,4,0"
                    IsEnabled="{Binding IsNotBusy}"/>
        </DockPanel>

        <!-- P-04〜P-06: 添付画像、P-13: サムネイル一覧(04書 G-003・G-013) -->
        <StackPanel Grid.Row="4" Orientation="Vertical" Margin="0,0,0,4">
            <TextBlock Text="添付画像" Margin="0,0,0,4"/>
            <DockPanel>
                <Button x:Name="ClearImagesButton" DockPanel.Dock="Right"
                        Content="クリア" Command="{Binding ClearImagesCommand}"
                        Padding="8,4" Margin="4,0,0,0" IsEnabled="{Binding IsNotBusy}"/>
                <Button x:Name="BrowseImageFolderButton" DockPanel.Dock="Right" Content="参照..."
                        Click="BrowseImageFolderButton_Click"
                        Padding="8,4" Margin="4,0,0,0" IsEnabled="{Binding IsNotBusy}"/>
                <TextBlock VerticalAlignment="Center">
                    <Run Text="{Binding AttachedImages.Count, Mode=OneWay}"/><Run Text="枚（投稿準備中）"/>
                </TextBlock>
            </DockPanel>
            <!-- P-13: サムネイル一覧・個別削除(04書 G-013)。横並び・横スクロール(フィルムストリップ風)。 -->
            <ScrollViewer Height="88" Margin="0,6,0,0"
                          HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding AttachedImages}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <!-- サムネイルのドラッグ&ドロップ並べ替え(04書 G-011)。ThumbnailItem_*はMainWindow.xaml.cs参照。 -->
                            <Grid Width="72" Height="72" Margin="0,0,6,0"
                                  AllowDrop="True"
                                  PreviewMouseLeftButtonDown="ThumbnailItem_PreviewMouseLeftButtonDown"
                                  MouseMove="ThumbnailItem_MouseMove"
                                  Drop="ThumbnailItem_Drop">
                                <Image Stretch="Uniform"
                                       Source="{Binding FilePath, Converter={StaticResource FilePathToThumbnailConverter}}"/>
                                <Button Content="×" Width="18" Height="18" Padding="0"
                                        HorizontalAlignment="Right" VerticalAlignment="Top"
                                        Command="{Binding DataContext.RemoveImageCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
            <!-- P-12: クリップボード画像貼り付け機能(G-010)の案内 -->
            <TextBlock Text="画像をコピーして Ctrl+V で貼り付けることもできます(複数ファイルの貼り付けにも対応)" Margin="0,4,0,0"
                       FontSize="11" Foreground="Gray"/>
        </StackPanel>

        <!-- P-08: 投稿する -->
        <Button Grid.Row="5" Content="投稿する" Command="{Binding PostCommand}"
                HorizontalAlignment="Right" Padding="16,6" Margin="0,0,0,8"/>
        </Grid>
        </TabItem>

        <!-- P-17・P-18: 定型文一覧とその投稿ボタン(04書 G-016)。
             選択状態を持たず、行の左側の「投稿」ボタン押下だけで投稿が完了する(G-016第1節)。 -->
        <TabItem Header="定型文">
            <Grid Margin="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Margin="0,0,0,8" TextWrapping="Wrap" Foreground="Gray" FontSize="11"
                           Text="設定(config/config.yaml)の templates に登録した定型文を、本文のみで投稿します(投稿タブの入力内容・添付画像は使いません)。"/>

                <!-- 定型文0件のとき(G-016第3節第4項)。一覧の代わりに登録方法を案内する。 -->
                <TextBlock Grid.Row="1" TextWrapping="Wrap" VerticalAlignment="Top"
                           Text="定型文が登録されていません。config/config.yaml の templates に登録してください">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasTemplates}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                              Visibility="{Binding HasTemplates, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <ItemsControl ItemsSource="{Binding Templates}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <DockPanel Margin="0,0,0,6">
                                    <Button DockPanel.Dock="Left" Content="投稿" Padding="12,4" Margin="0,0,8,0"
                                            VerticalAlignment="Top"
                                            Command="{Binding DataContext.PostTemplateCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"/>
                                    <!-- 押下前に投稿内容を確認できるよう、複数行の定型文も省略せず折り返して全文表示する(G-016第3節第3項)。 -->
                                    <TextBlock Text="{Binding}" TextWrapping="Wrap" VerticalAlignment="Center"/>
                                </DockPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </TabItem>
        </TabControl>

        <!-- P-09〜P-10: 結果ログ -->
        <DockPanel Grid.Row="1" Margin="0,0,0,8">
            <DockPanel DockPanel.Dock="Top" LastChildFill="False">
                <TextBlock Text="結果ログ" VerticalAlignment="Center"/>
                <Button DockPanel.Dock="Right" Content="ログをクリア" Command="{Binding ClearLogCommand}"
                        Padding="6,2" HorizontalAlignment="Right"/>
            </DockPanel>
            <ListBox ItemsSource="{Binding LogEntries}" IsEnabled="True" MinHeight="100" MaxHeight="180">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Message}" TextWrapping="Wrap">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Severity}" Value="Success">
                                            <Setter Property="Foreground" Value="Green"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Severity}" Value="Warning">
                                            <Setter Property="Foreground" Value="DarkOrange"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Severity}" Value="Error">
                                            <Setter Property="Foreground" Value="Red"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>

        <!-- P-11: バージョン表示 -->
        <TextBlock Grid.Row="2" Text="{Binding VersionText}"
                   HorizontalAlignment="Right" Foreground="Gray"/>
    </Grid>
</Window>
